// @version=6
// 01-base.pine — Papan Gerak: Header, Inputs, Tema, Utilities
// ==========================================================

// --- Indicator Definition ---
indicator(
    "Saham: Papan Gerak By. Akhmfz",
    overlay = false,
    format = format.price,
    precision = 0,
    max_labels_count = 50,
    max_lines_count = 50
)

// ==========================================================
// 1. SETTINGS — General
// ==========================================================
// --- Display ---
tablePositionInput = input.string(
    "Top Right",
    "Table Position",
    options = ["Top Left", "Top Right", "Bottom Left", "Bottom Right"],
    display = display.data_window
)
fontSizeInput = input.int(1, "Font Size", minval = 1, maxval = 3, display = display.data_window)
modeInput = input.string("Standard", "Mode", options = ["Compact", "Standard", "Detailed"], display = display.data_window)
bahasaInput = input.string("Indonesia", "Bahasa", options = ["Indonesia", "English"], display = display.data_window)
colorThemeInput = input.string("Gelap", "Color Theme", options = ["Gelap", "Terang", "Bursa Hijau", "Biru Nusantara", "Emas Premium"], display = display.data_window)

// ==========================================================
// 2. SETTINGS — Trend Parameters
// ==========================================================
emaFastPeriod = input.int(20, "EMA Fast Period", group = "Trend", display = display.data_window)
emaMidPeriod = input.int(50, "EMA Mid Period", group = "Trend", display = display.data_window)
emaSlowPeriod = input.int(200, "EMA Slow Period", group = "Trend", display = display.data_window)
superTrendFactor = input.float(3.0, "SuperTrend Factor", step = 0.1, group = "Trend", display = display.data_window)
superTrendPeriod = input.int(10, "SuperTrend ATR Period", group = "Trend", display = display.data_window)
adxLength = input.int(14, "ADX Length", group = "Trend", display = display.data_window)
adxThreshold = input.int(25, "ADX Threshold", group = "Trend", display = display.data_window)

// ==========================================================
// 3. SETTINGS — Momentum Parameters
// ==========================================================
rsiLength = input.int(14, "RSI Length", group = "Momentum", display = display.data_window)
rsiOb = input.int(70, "RSI Overbought", group = "Momentum", display = display.data_window)
rsiOs = input.int(30, "RSI Oversold", group = "Momentum", display = display.data_window)
macdFast = input.int(12, "MACD Fast", group = "Momentum", display = display.data_window)
macdSlow = input.int(26, "MACD Slow", group = "Momentum", display = display.data_window)
macdSignal = input.int(9, "MACD Signal", group = "Momentum", display = display.data_window)
stochK = input.int(14, "Stochastic K", group = "Momentum", display = display.data_window)
stochD = input.int(3, "Stochastic D", group = "Momentum", display = display.data_window)
stochOb = input.int(80, "Stoch Overbought", group = "Momentum", display = display.data_window)
stochOs = input.int(20, "Stoch Oversold", group = "Momentum", display = display.data_window)

// ==========================================================
// 4. SETTINGS — Volatility Parameters
// ==========================================================
atrLength = input.int(14, "ATR Length", group = "Volatility", display = display.data_window)
bbLength = input.int(20, "Bollinger Length", group = "Volatility", display = display.data_window)
bbMult = input.float(2.0, "Bollinger Multiplier", step = 0.1, group = "Volatility", display = display.data_window)
chopLength = input.int(14, "Choppiness Length", group = "Volatility", display = display.data_window)

// ==========================================================
// 5. SETTINGS — Volume Parameters
// ==========================================================
volMaLength = input.int(20, "Volume MA Length", group = "Volume", display = display.data_window)
volSpikeMult = input.float(2.0, "Volume Spike Multiplier", step = 0.1, group = "Volume", display = display.data_window)

// ==========================================================
// 6. SETTINGS — Scoring Weights
// ==========================================================
weightTrend = input.int(30, "Trend Weight (%)", minval = 0, maxval = 100, step = 5, group = "Weights", display = display.data_window)
weightMomentum = input.int(30, "Momentum Weight (%)", minval = 0, maxval = 100, step = 5, group = "Weights", display = display.data_window)
weightVolatility = input.int(20, "Volatility Weight (%)", minval = 0, maxval = 100, step = 5, group = "Weights", display = display.data_window)
weightVolume = input.int(20, "Volume Weight (%)", minval = 0, maxval = 100, step = 5, group = "Weights", display = display.data_window)

// ==========================================================
// 7. SETTINGS — Smart Money (Optional)
// ==========================================================
enableSmartMoney = input.bool(false, "Enable Smart Money Flow", group = "Smart Money", display = display.data_window)
weightSmartMoney = input.int(20, "SM Weight (%)", minval = 0, maxval = 100, step = 5, group = "Smart Money", display = display.data_window)
smVolumeThreshold = input.float(2.5, "SM Volume Z-Threshold", step = 0.1, group = "Smart Money", display = display.data_window)
smPeriod = input.int(20, "SM Lookback Period", group = "Smart Money", display = display.data_window)

// ==========================================================
// 8. COLOR THEMES
// ==========================================================
var color bgColor = na
var color headerColor = na
var color labelColor = na
var color scoreColor = na
var color tableBgColor = na
var color bullColor = na
var color bearColor = na
var color neutralColor = na
var color signalLineColor = na
var color dimTrend = na
var color dimMomentum = na
var color dimVolatility = na
var color dimVolume = na

if colorThemeInput == "Gelap"
    bgColor := color.rgb(0, 0, 0, 85)
    headerColor := color.rgb(38, 166, 154)
    labelColor := color.white
    scoreColor := color.rgb(38, 166, 154)
    tableBgColor := color.rgb(13, 22, 30, 90)
    bullColor := color.rgb(38, 166, 154)
    bearColor := color.rgb(239, 83, 80)
    neutralColor := color.rgb(255, 202, 40)
    signalLineColor := color.rgb(100, 100, 100)
    dimTrend := color.rgb(66, 165, 245)
    dimMomentum := color.rgb(255, 202, 40)
    dimVolatility := color.rgb(239, 83, 80)
    dimVolume := color.rgb(126, 87, 194)
else
    if colorThemeInput == "Terang"
        bgColor := color.rgb(255, 255, 255, 85)
        headerColor := color.rgb(0, 150, 136)
        labelColor := color.rgb(33, 33, 33)
        scoreColor := color.rgb(0, 150, 136)
        tableBgColor := color.rgb(245, 245, 245, 90)
        bullColor := color.rgb(0, 150, 136)
        bearColor := color.rgb(211, 47, 47)
        neutralColor := color.rgb(255, 160, 0)
        signalLineColor := color.rgb(158, 158, 158)
        dimTrend := color.rgb(33, 150, 243)
        dimMomentum := color.rgb(255, 193, 7)
        dimVolatility := color.rgb(244, 67, 54)
        dimVolume := color.rgb(156, 39, 176)
    else
        if colorThemeInput == "Bursa Hijau"
            bgColor := color.rgb(0, 30, 0, 85)
            headerColor := color.rgb(76, 175, 80)
            labelColor := color.white
            scoreColor := color.rgb(76, 175, 80)
            tableBgColor := color.rgb(0, 20, 0, 90)
            bullColor := color.rgb(76, 175, 80)
            bearColor := color.rgb(244, 67, 54)
            neutralColor := color.rgb(255, 235, 59)
            signalLineColor := color.rgb(100, 100, 100)
            dimTrend := color.rgb(129, 199, 132)
            dimMomentum := color.rgb(255, 235, 59)
            dimVolatility := color.rgb(239, 83, 80)
            dimVolume := color.rgb(186, 104, 200)
        else
            if colorThemeInput == "Biru Nusantara"
                bgColor := color.rgb(0, 20, 50, 85)
                headerColor := color.rgb(41, 98, 255)
                labelColor := color.white
                scoreColor := color.rgb(41, 98, 255)
                tableBgColor := color.rgb(0, 10, 30, 90)
                bullColor := color.rgb(41, 98, 255)
                bearColor := color.rgb(255, 82, 82)
                neutralColor := color.rgb(255, 202, 40)
                signalLineColor := color.rgb(100, 100, 100)
                dimTrend := color.rgb(100, 181, 246)
                dimMomentum := color.rgb(255, 202, 40)
                dimVolatility := color.rgb(239, 83, 80)
                dimVolume := color.rgb(179, 136, 255)
            else
                bgColor := color.rgb(30, 20, 0, 85)
                headerColor := color.rgb(255, 193, 7)
                labelColor := color.rgb(33, 33, 33)
                scoreColor := color.rgb(255, 193, 7)
                tableBgColor := color.rgb(20, 15, 0, 90)
                bullColor := color.rgb(76, 175, 80)
                bearColor := color.rgb(244, 67, 54)
                neutralColor := color.rgb(255, 193, 7)
                signalLineColor := color.rgb(158, 158, 158)
                dimTrend := color.rgb(255, 183, 77)
                dimMomentum := color.rgb(255, 213, 79)
                dimVolatility := color.rgb(239, 83, 80)
                dimVolume := color.rgb(206, 147, 216)

// ==========================================================
// 9. UTILITY FUNCTIONS
// ==========================================================
f_secure(input, def) => na(input) ? def : input

f_scoreHigher(float val, float min, float max) =>
    na(val) ? na : math.max(0, math.min(100, (val - min) / (max - min) * 100))

f_scoreLower(float val, float min, float max) =>
    na(val) ? na : math.max(0, math.min(100, (max - val) / (max - min) * 100))

f_scoreRange(float val, float min, float max, float idealLow, float idealHigh) =>
    if na(val)
        na
    else
        if val >= idealLow and val <= idealHigh
            100.0
        else
            if val < idealLow
                if val <= min
                    0.0
                else
                    (val - min) / (idealLow - min) * 100
            else
                if val >= max
                    0.0
                else
                    (max - val) / (max - idealHigh) * 100

f_scoreBias(float val) =>
    na(val) ? na : (val + 1) / 2 * 100

f_colorScore(float score) =>
    if na(score)
        color.gray
    else
        if score >= 70
            bullColor
        else
            if score >= 40
                neutralColor
            else
                bearColor

f_signalText(float score, string lang) =>
    if na(score)
        lang == "Indonesia" ? "N/A" : "N/A"
    else
        if score >= 70
            lang == "Indonesia" ? "BULLISH" : "BULLISH"
        else
            if score >= 40
                lang == "Indonesia" ? "NETRAL" : "NEUTRAL"
            else
                lang == "Indonesia" ? "BEARISH" : "BEARISH"

// @version=6
// 02-data.pine — Papan Gerak: Market Engine & TA Calculations
// ==========================================================

// ==========================================================
// 1. TREND INDICATORS
// ==========================================================
// --- EMA ---
emaFast = ta.ema(close, emaFastPeriod)
emaMid = ta.ema(close, emaMidPeriod)
emaSlow = ta.ema(close, emaSlowPeriod)

// EMA Position Score component
emaPosition = close > emaFast ? (close > emaMid ? (close > emaSlow ? 2 : 1) : 0) : -1
emaTrend = close > emaSlow ? 1 : -1

// --- SuperTrend ---
[superTrend, superTrendDir] = ta.supertrend(superTrendFactor, superTrendPeriod)
stBullish = superTrendDir == 1

// --- ADX / DMI ---
[adxUp, adxDn, adxValue] = ta.dmi(adxLength, adxLength)

// ADX strength
adxStrong = adxValue >= adxThreshold
adxTrend = adxUp > adxDn ? 1 : -1
// Trend alignment
trendAligned = (adxTrend == 1 and stBullish and emaTrend == 1) or (adxTrend == -1 and not stBullish and emaTrend == -1)

// ==========================================================
// 2. MOMENTUM INDICATORS
// ==========================================================
// --- RSI ---
rsiValue = ta.rsi(close, rsiLength)
rsiObHit = rsiValue >= rsiOb
rsiOsHit = rsiValue <= rsiOs
rsiDirection = ta.rising(rsiValue, 1) ? 1 : -1

// --- MACD ---
[macdLine, macdSignalLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSignal)
macdBullish = macdLine > macdSignalLine
macdHistRising = macdHist > macdHist[1]
macdZero = macdLine > 0

// --- Stochastic ---
stochKVal = ta.stoch(close, high, low, stochK)
stochDVal = ta.sma(stochKVal, stochD)
stochBullish = stochKVal > stochDVal
stochObHit = stochKVal >= stochOb
stochOsHit = stochKVal <= stochOs

// ==========================================================
// 3. VOLATILITY INDICATORS
// ==========================================================
// --- ATR% (normalized) ---
atrValue = ta.atr(atrLength)
atrPercent = atrValue / close * 100

// --- Bollinger Bands Width ---
bbMiddle = ta.sma(close, bbLength)
bbStdDev = ta.stdev(close, bbLength)
bbUpper = bbMiddle + bbMult * bbStdDev
bbLower = bbMiddle - bbMult * bbStdDev
bbWidth = (bbUpper - bbLower) / bbMiddle * 100
bbWidthAvg = ta.sma(bbWidth, bbLength)

// Price position within bands (0-100)
bbPosition = (close - bbLower) / (bbUpper - bbLower) * 100

// --- Choppiness Index ---
f_choppiness(int length) =>
    highestHigh = ta.highest(high, length)
    lowestLow = ta.lowest(low, length)
    atrSum = math.sum(ta.atr(1), length)
    range_ = highestHigh - lowestLow
    if range_ == 0
        100.0
    else
        math.log(atrSum / range_) / math.log(length) * 100

chopValue = f_choppiness(chopLength)
chopTrending = chopValue <= 38
chopRanging = chopValue >= 62

// ==========================================================
// 4. VOLUME INDICATORS
// ==========================================================
// --- Volume MA ---
volMA = ta.sma(volume, volMaLength)
volRatio = volume / volMA
volSpike = volRatio >= volSpikeMult

// --- OBV ---
obvValue = ta.obv
obvMA = ta.sma(obvValue, volMaLength)
obvTrend = obvValue > obvMA ? 1 : -1
obvAgree = (obvTrend == 1 and close > close[1]) or (obvTrend == -1 and close < close[1])

// --- Net Volume (proxy) ---
f_netVolume() =>
    upVol = volume * (close - open) / (high - low + 1e-10)
    na(upVol) ? 0 : upVol

netVol = f_netVolume()
netVolSmooth = ta.sma(netVol, 5)

// ==========================================================
// 5. SMART MONEY FLOW (Optional)
// ==========================================================
// Institutional flow detection via volume Z-score
f_smartMoneyDetect() =>
    if not enableSmartMoney
        false
    else
        volSMA = ta.sma(volume, smPeriod)
        volStd = ta.stdev(volume, smPeriod)
        if volStd == 0
            false
        else
            zScore = (volume - volSMA) / volStd
            zScore >= smVolumeThreshold and close > open

// Volume inside body (institutional) vs at wick (retail)
f_isBodyVolume() =>
    bodyRange = math.abs(close - open)
    totalRange = high - low
    if totalRange == 0
        false
    else
        bodyRange / totalRange >= 0.6 and volSpike

smDetected = f_smartMoneyDetect()
smBodyVol = f_isBodyVolume()

// Cumulative SM score
smScore = if enableSmartMoney
    score = 50.0
    if smDetected
        score += 25
    if smBodyVol
        score += 15
    if obvAgree
        score += 10
    score
else
    na

// @version=6
// 03-scoring.pine — Papan Gerak: Scoring Engine + Render
// ==========================================================

// ==========================================================
// 1. TREND SCORE (0-100)
// ==========================================================
f_trendScore() =>
    scoreSum = 0.0
    count = 0.0

    // EMA Position (weight: 3)
    pos = emaPosition
    if not na(pos)
        scoreSum += (pos + 1) / 3 * 100 * 3
        count += 3

    // SuperTrend Direction (weight: 2)
    if not na(superTrendDir)
        scoreSum += (superTrendDir == 1 ? 100 : 0) * 2
        count += 2

    // ADX Strength (weight: 2)
    if not na(adxValue)
        adxScore = adxStrong ? (adxTrend == 1 ? 80 : 20) : 50
        scoreSum += adxScore * 2
        count += 2

    // Trend Alignment (weight: 2)
    if not na(adxValue)
        alignScore = trendAligned ? (adxTrend == 1 ? 100 : 0) : 50
        scoreSum += alignScore * 2
        count += 2

    // EMA Slope (weight: 1)
    slopeFast = emaFast - emaFast[5]
    if not na(slopeFast)
        slopeScore = f_scoreHigher(slopeFast, -close * 0.02, close * 0.02)
        scoreSum += slopeScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 2. MOMENTUM SCORE (0-100)
// ==========================================================
f_momentumScore() =>
    scoreSum = 0.0
    count = 0.0

    // RSI (weight: 3)
    if not na(rsiValue)
        rsiScore = f_scoreHigher(rsiValue, 30, 70)
        scoreSum += rsiScore * 3
        count += 3

    // MACD (weight: 3)
    if not na(macdHist)
        macdScore = 50.0
        if macdBullish and macdHistRising
            macdScore := macdZero ? 90 : 70
        else
            if macdBullish
                macdScore := macdZero ? 70 : 55
            else
                if macdHistRising
                    macdScore := 45
                else
                    macdScore := macdZero ? 35 : 10
        scoreSum += macdScore * 3
        count += 3

    // Stochastic (weight: 2)
    if not na(stochKVal)
        stochScore = f_scoreHigher(stochKVal, 20, 80)
        scoreSum += stochScore * 2
        count += 2

    // RSI Direction (weight: 1)
    if not na(rsiDirection)
        dirScore = rsiDirection == 1 ? 70 : 30
        scoreSum += dirScore * 1
        count += 1

    // MACD Histogram Slope (weight: 1)
    if not na(macdHist) and not na(macdHist[2])
        slopeScore = macdHist > macdHist[2] ? 70 : 30
        scoreSum += slopeScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 3. VOLATILITY SCORE (0-100)
// ==========================================================
f_volatilityScore() =>
    scoreSum = 0.0
    count = 0.0

    // Bollinger Width vs Average (weight: 3)
    if not na(bbWidth) and not na(bbWidthAvg)
        // Squeeze = low volatility, Expansion = high volatility
        widthRatio = bbWidth / bbWidthAvg
        // Ideal: moderate volatility (0.8-1.2x average)
        volScore = f_scoreRange(widthRatio, 0.3, 3.0, 0.8, 1.2)
        scoreSum += volScore * 3
        count += 3

    // Choppiness Index (weight: 3)
    if not na(chopValue)
        // Low chop = trending (good), High chop = ranging (bad)
        chopScore = 100 - math.min(100, chopValue)
        scoreSum += chopScore * 3
        count += 3

    // ATR% (weight: 2)
    if not na(atrPercent)
        // Moderate ATR is ideal
        atrScore = f_scoreRange(atrPercent, 0.5, 10.0, 1.0, 3.0)
        scoreSum += atrScore * 2
        count += 2

    // Bollinger Position (weight: 1)
    if not na(bbPosition)
        // Price near middle = moderate, near bands = extreme
        posScore = 100 - math.abs(bbPosition - 50) * 2
        scoreSum += posScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 4. VOLUME SCORE (0-100)
// ==========================================================
f_volumeScore() =>
    scoreSum = 0.0
    count = 0.0

    // Volume vs MA (weight: 3)
    if not na(volRatio)
        volScore = f_scoreRange(volRatio, 0.2, 5.0, 0.8, 2.0)
        scoreSum += volScore * 3
        count += 3

    // OBV Agreement (weight: 3)
    if not na(obvValue)
        obvScore = obvAgree ? 80 : 30
        scoreSum += obvScore * 3
        count += 3

    // Net Volume Direction (weight: 2)
    if not na(netVolSmooth)
        netScore = netVolSmooth > 0 ? 70 : 30
        scoreSum += netScore * 2
        count += 2

    // Volume Spike Quality (weight: 1)
    if not na(volRatio)
        spikeScore = volSpike ? 80 : 50
        scoreSum += spikeScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 5. SMART MONEY SCORE (Optional, 0-100)
// ==========================================================
f_smartMoneyScore() =>
    if not enableSmartMoney
        na
    else
        scoreSum = 0.0
        count = 0.0

        // SM Detection (weight: 3)
        if not na(volume)
            scoreSum += (smDetected ? 90 : 50) * 3
            count += 3

        // Body Volume (weight: 2)
        if not na(volume)
            scoreSum += (smBodyVol ? 80 : 50) * 2
            count += 2

        // OBV Alignment (weight: 2)
        if not na(obvValue)
            scoreSum += (obvAgree ? 75 : 40) * 2
            count += 2

        // Net Volume (weight: 1)
        if not na(netVolSmooth)
            scoreSum += (netVolSmooth > 0 ? 70 : 40) * 1
            count += 1

        count > 0 ? scoreSum / count : na

// ==========================================================
// 6. CALCULATE ALL SCORES
// ==========================================================
trendScore = f_trendScore()
momentumScore = f_momentumScore()
volatilityScore = f_volatilityScore()
volumeScore = f_volumeScore()
smartMoneyScore = f_smartMoneyScore()

// Normalize weights
totalWeight = weightTrend + weightMomentum + weightVolatility + weightVolume
normTrend = totalWeight > 0 ? weightTrend / totalWeight * 100 : 25
normMomentum = totalWeight > 0 ? weightMomentum / totalWeight * 100 : 25
normVolatility = totalWeight > 0 ? weightVolatility / totalWeight * 100 : 25
normVolume = totalWeight > 0 ? weightVolume / totalWeight * 100 : 25

float overallScore = na
if not na(trendScore) or not na(momentumScore) or not na(volatilityScore) or not na(volumeScore)
    sum = 0.0
    wSum = 0.0
    if not na(trendScore)
        sum += trendScore * normTrend
        wSum += normTrend
    if not na(momentumScore)
        sum += momentumScore * normMomentum
        wSum += normMomentum
    if not na(volatilityScore)
        sum += volatilityScore * normVolatility
        wSum += normVolatility
    if not na(volumeScore)
        sum += volumeScore * normVolume
        wSum += normVolume
    if not na(smartMoneyScore) and enableSmartMoney
        sum += smartMoneyScore * weightSmartMoney
        wSum += weightSmartMoney
    overallScore := wSum > 0 ? sum / wSum : na

// ==========================================================
// 7. SIGNAL GENERATION
// ==========================================================
signalText = f_signalText(overallScore, bahasaInput)
signalColor = f_colorScore(overallScore)

// ==========================================================
// 8. CONFLUENCE COUNTERS (berapa sub-indikator setuju per dimensi)
// ==========================================================
// Trend
trendBull = 0
trendTotal = 0
if not na(emaPosition)
    trendBull += emaPosition >= 1 ? 1 : 0
    trendTotal += 1
if not na(superTrendDir)
    trendBull += superTrendDir == 1 ? 1 : 0
    trendTotal += 1
if not na(adxValue)
    trendBull += adxTrend == 1 ? 1 : 0
    trendTotal += 1
if not na(adxValue)
    trendBull += trendAligned ? 1 : 0
    trendTotal += 1

// Momentum
momBull = 0
momTotal = 0
if not na(rsiValue)
    momBull += rsiValue > 50 ? 1 : 0
    momTotal += 1
if not na(macdBullish)
    momBull += macdBullish ? 1 : 0
    momTotal += 1
if not na(stochBullish)
    momBull += stochBullish ? 1 : 0
    momTotal += 1
if not na(rsiDirection)
    momBull += rsiDirection == 1 ? 1 : 0
    momTotal += 1
if not na(macdHistRising)
    momBull += macdHistRising ? 1 : 0
    momTotal += 1

// Volatility ("ideal" = trending/tenang, bukan ranging/liar)
volBull = 0
volTotal = 0
if not na(bbWidth) and not na(bbWidthAvg)
    volBull += (bbWidth / bbWidthAvg >= 0.8 and bbWidth / bbWidthAvg <= 1.2) ? 1 : 0
    volTotal += 1
if not na(chopValue)
    volBull += chopValue < 50 ? 1 : 0
    volTotal += 1
if not na(atrPercent)
    volBull += (atrPercent >= 1.0 and atrPercent <= 3.0) ? 1 : 0
    volTotal += 1
if not na(bbPosition)
    volBull += (bbPosition >= 30 and bbPosition <= 70) ? 1 : 0
    volTotal += 1

// Volume
volmBull = 0
volmTotal = 0
if not na(volRatio)
    volmBull += volRatio >= 0.8 ? 1 : 0
    volmTotal += 1
if not na(obvAgree)
    volmBull += obvAgree ? 1 : 0
    volmTotal += 1
if not na(netVolSmooth)
    volmBull += netVolSmooth > 0 ? 1 : 0
    volmTotal += 1
if not na(volSpike)
    volmBull += volSpike ? 1 : 0
    volmTotal += 1

// ==========================================================
// 9. TOOLTIP STRINGS (detail per dimensi untuk hover)
// ==========================================================
// Trend tooltip
trendDetail = "—"
if not na(emaPosition) and not na(trendScore)
    emaLabel = emaPosition >= 1 ? "Price > EMA50 ✓" : emaPosition >= 0 ? "Price > EMA20" : "Price < EMAs ✗"
    stLabel = not na(superTrendDir) ? (superTrendDir == 1 ? "SuperTrend Up ✓" : "SuperTrend Down ✗") : ""
    adxLabel = not na(adxValue) ? (adxStrong ? (adxTrend == 1 ? "ADX " + str.tostring(math.round(adxValue)) + " (strong) ✓" : "ADX " + str.tostring(math.round(adxValue)) + " (strong, down)") : "ADX " + str.tostring(math.round(adxValue)) + " (weak)") : ""
    alignLabel = not na(adxValue) ? (trendAligned ? "Aligned ✓" : "Mixed") : ""
    trendDetail = emaLabel + " | " + stLabel + " | " + adxLabel + " | " + alignLabel

// Momentum tooltip
momDetail = "—"
if not na(rsiValue) and not na(momentumScore)
    rsiLbl = rsiValue >= rsiOb ? "RSI " + str.tostring(math.round(rsiValue)) + " Overbought" : rsiValue <= rsiOs ? "RSI " + str.tostring(math.round(rsiValue)) + " Oversold" : "RSI " + str.tostring(math.round(rsiValue)) + " Netral"
    macdLbl = macdBullish ? (macdHistRising ? "MACD Bullish + hist ↑" : "MACD Bullish + hist ↓") : (macdHistRising ? "MACD Bearish + hist ↑" : "MACD Bearish + hist ↓")
    stochLbl = not na(stochKVal) ? (stochKVal >= stochOb ? "Stoch Overbought" : stochKVal <= stochOs ? "Stoch Oversold" : "Stoch " + str.tostring(math.round(stochKVal)) + " Netral") : ""
    momDetail = rsiLbl + " | " + macdLbl + " | " + stochLbl

// Volatility tooltip
volDetail = "—"
if not na(bbWidth) and not na(atrPercent) and not na(volatilityScore)
    bbRatio = bbWidth / bbWidthAvg
    bbLbl = bbRatio >= 0.8 and bbRatio <= 1.2 ? "BB Moderate ✓" : bbRatio < 0.8 ? "BB Squeeze" : "BB Expand"
    chopLbl = not na(chopValue) ? (chopValue <= 38 ? "Chop " + str.tostring(math.round(chopValue)) + " Trending ✓" : chopValue >= 62 ? "Chop " + str.tostring(math.round(chopValue)) + " Ranging" : "Chop " + str.tostring(math.round(chopValue)) + " Netral") : ""
    atrLbl = "ATR " + str.tostring(math.round(atrPercent * 10) / 10) + "%"
    bbPosLbl = not na(bbPosition) ? (bbPosition >= 30 and bbPosition <= 70 ? "BB Pos " + str.tostring(math.round(bbPosition)) + " Mid ✓" : "BB Pos " + str.tostring(math.round(bbPosition)) + " Edge") : ""
    volDetail = bbLbl + " | " + chopLbl + " | " + atrLbl + " | " + bbPosLbl

// Volume tooltip
volmDetail = "—"
if not na(volRatio) and not na(volumeScore)
    vrLbl = volRatio >= volSpikeMult ? "Vol " + str.tostring(math.round(volRatio * 10) / 10) + "x (spike!)" : volRatio >= 0.8 ? "Vol " + str.tostring(math.round(volRatio * 10) / 10) + "x (healthy) ✓" : "Vol " + str.tostring(math.round(volRatio * 10) / 10) + "x (low)"
    obvLbl = not na(obvAgree) ? (obvAgree ? "OBV Agree ✓" : "OBV Diverge ✗") : ""
    netLbl = not na(netVolSmooth) ? (netVolSmooth > 0 ? "Net Vol + Bullish" : "Net Vol - Bearish") : ""
    volmDetail = vrLbl + " | " + obvLbl + " | " + netLbl

// ==========================================================
// 10. NARRATIVE (1 baris insight untuk trader)
// ==========================================================
f_narrative() =>
    lang = bahasaInput

    // Konflik: Momentum kuat tapi RSI overbought
    if not na(momentumScore) and not na(rsiValue) and not na(overallScore)
        if momentumScore >= 65 and rsiValue >= rsiOb
            lang == "Indonesia" ? "⚠️  Momentum kuat tapi RSI overbought — waspada koreksi" : "⚠️  Strong momentum but RSI overbought — watch for pullback"

        // RSI oversold + volume spike = potensi bounce
        else if rsiValue <= rsiOs and not na(volSpike) and volSpike
            lang == "Indonesia" ? "📈 RSI oversold + volume spike — potensi bounce" : "📈 RSI oversold + volume spike — potential bounce"

        // Tren lemah & volatil
        else if not na(trendScore) and not na(volatilityScore)
            if trendScore < 40 and volatilityScore < 40
                lang == "Indonesia" ? "⚠️  Tren lemah & volatil — hindari entry baru" : "⚠️  Weak trend & volatile — avoid new entries"

        // OBV divergen
        else if not na(close) and not na(obvAgree)
            if close > close[10] and not obvAgree
                lang == "Indonesia" ? "⚠️  Harga naik tapi OBV divergen — konfirmasi dulu" : "⚠️  Price up but OBV diverging — confirm first"

        // Volume spike + trend align = konfirmasi
        else if not na(trendScore) and not na(volmBull) and not na(volmTotal)
            if trendScore >= 65 and volmBull >= 3 and volmTotal >= 3
                lang == "Indonesia" ? "✅ Volume konfirmasi tren — bias searah" : "✅ Volume confirms trend — trade with trend"

        // Ranging market
        else if not na(chopRanging) and chopRanging
            lang == "Indonesia" ? "⏳ Pasar ranging — tunggu breakout" : "⏳ Ranging market — wait for breakout"

        // Semua align
        else if not na(overallScore)
            if overallScore >= 70 and volmBull >= 3 and trendScore >= 65
                lang == "Indonesia" ? "✅ Semua dimensi align — bias bullish" : "✅ All dimensions aligned — bullish bias"
            else if overallScore <= 30 and volmBull <= 1 and trendScore <= 35
                lang == "Indonesia" ? "✅ Semua dimensi align — bias bearish" : "✅ All dimensions aligned — bearish bias"
            else
                lang == "Indonesia" ? "💡 Kondisi campuran — cek detail per dimensi" : "💡 Mixed conditions — check per-dimension details"
    else
        lang == "Indonesia" ? "⏳ Menunggu data..." : "⏳ Waiting for data..."

narrative = f_narrative()

// ==========================================================
// 11. INLINE VALIDATION (forward return sejak sinyal terakhir)
// ==========================================================
var float signalEntryPrice = na
var int signalEntryBar = na
var int signalDirection = 0  // 1 = bullish (cross above 40/70), -1 = bearish (cross below)
var string signalLabel = ""

// Track signal changes
if ta.cross(overallScore, 40)
    signalEntryPrice := close
    signalEntryBar := bar_index
    signalDirection := overallScore > 40 ? 1 : -1
    signalLabel := overallScore > 40 ? "Cross >40 (Bullish)" : "Cross <40 (Bearish)"
else if ta.cross(overallScore, 70)
    signalEntryPrice := close
    signalEntryBar := bar_index
    signalDirection := overallScore > 70 ? 1 : -1
    signalLabel := overallScore > 70 ? "Cross >70 (Bullish)" : "Cross <70 (Bearish)"

// Forward return sejak sinyal (searah: positif = prediksi benar)
fwdReturn = na(signalEntryPrice) or signalEntryPrice == 0 ? na : (close / signalEntryPrice - 1) * signalDirection * 100

// Status: apakah sinyal saat ini untung atau rugi
signalStatus = na(fwdReturn) ? "" : fwdReturn >= 5 ? "✅ +" + str.tostring(math.round(fwdReturn)) + "%" : fwdReturn >= 0 ? "➖ +" + str.tostring(math.round(fwdReturn)) + "%" : fwdReturn >= -5 ? "➖ " + str.tostring(math.round(fwdReturn)) + "%" : "❌ " + str.tostring(math.round(fwdReturn)) + "%"

fwdBars = na(signalEntryBar) ? na : bar_index - signalEntryBar

// @version=6
// 04-ui.pine — Papan Gerak: Table & Signal Rendering
// ==========================================================

// ==========================================================
// 1. SIGNAL LINE (Overall Score as Oscillator)
// ==========================================================
hline(70, "OB Line", color = color.rgb(239, 83, 80, 60), linestyle = hline.style_dashed)
hline(40, "OS Line", color = color.rgb(38, 166, 154, 60), linestyle = hline.style_dashed)
hline(50, "Midline", color = color.rgb(100, 100, 100, 40), linestyle = hline.style_dotted)

plot(overallScore, "Overall Score", signalColor, 2, plot.style_line)
fill(plot(70), plot(40), color = color.rgb(100, 100, 100, 10))

oscBg = na(overallScore) ? color.new(color.gray, 95) : overallScore >= 70 ? color.new(bullColor, 88) : overallScore >= 40 ? color.new(neutralColor, 88) : color.new(bearColor, 88)
bgcolor(oscBg, title = "Score Zone")

// ==========================================================
// 2. BUILD TABLE
// ==========================================================
f_getPosition() =>
    if tablePositionInput == "Top Left"
        position.top_left
    else
        if tablePositionInput == "Bottom Left"
            position.bottom_left
        else
            if tablePositionInput == "Bottom Right"
                position.bottom_right
            else
                position.top_right

f_getFontSize() =>
    if fontSizeInput == 1
        size.small
    else
        if fontSizeInput == 2
            size.normal
        else
            size.large

f_confStr(n, total) =>
    str.tostring(n) + "/" + str.tostring(total)

tablePos = f_getPosition()
fontSz = f_getFontSize()

// Render on last bar only
if barstate.islast
    // --- Compact Mode ---
    if modeInput == "Compact"
        tblCompact = table.new(tablePos, 2, 1, bgcolor = tableBgColor, border_width = 1, border_color = signalColor)
        overallDisplay = str.tostring(math.round(overallScore))
        table.cell(tblCompact, 0, 0, "PAPAN GERAK  " + signalText + "  " + overallDisplay,
         text_color = signalColor, text_size = fontSz, text_halign = text.align_center, width = 10)

    else
        // --- Standard & Detailed Mode ---
        isDetailed = modeInput == "Detailed"
        rowCount = 9
        if enableSmartMoney
            rowCount := 9
        if isDetailed
            rowCount := rowCount + 4  // +1 sub-row per dimensi
        tblFull = table.new(tablePos, 3, rowCount, bgcolor = tableBgColor, border_width = 1, border_color = signalColor,
         frame_color = signalColor, frame_width = 1)

        // Narrative row (full width)
        table.merge_cells(tblFull, 0, 0, 3, 1)
        table.cell(tblFull, 0, 0, narrative, text_color = headerColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Header
        table.cell(tblFull, 0, 1, "PAPAN GERAK", text_color = headerColor, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        overallDisplay = str.tostring(math.round(overallScore))
        overallTip = not na(overallScore) ? (overallScore >= 70 ? "Bullish: overall >70" : overallScore >= 40 ? "Neutral: 40-70" : "Bearish: <40") : ""
        table.cell(tblFull, 1, 1, overallDisplay, text_color = signalColor, text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = overallTip)

        // Signal
        table.cell(tblFull, 0, 2, bahasaInput == "Indonesia" ? "Sinyal" : "Signal", text_color = labelColor, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, 2, signalText, text_color = signalColor, text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor)

        // Signal Validation (forward return)
        valLabel = bahasaInput == "Indonesia" ? "Sinyal" : "Signal"
        valDisplay = not na(signalStatus) and signalStatus != "" ? signalStatus : "—"
        valTooltip = not na(fwdBars) and not na(signalLabel) ? signalLabel + " | Bars: " + str.tostring(fwdBars) : ""
        table.cell(tblFull, 0, 3, "  📊 " + valLabel, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, 3, valDisplay, text_color = labelColor, text_size = size.small, text_halign = text.align_right, bgcolor = bgColor, tooltip = valTooltip)

        // Trend
        trendDisplay = str.tostring(math.round(trendScore))
        trendArrow = not na(trendScore) ? (trendScore >= 70 ? "↑" : trendScore >= 40 ? "→" : "↓") : "—"
        trendConf = not na(trendBull) ? " (" + f_confStr(trendBull, trendTotal) + ")" : ""
        table.cell(tblFull, 0, 4, "  " + trendArrow + " " + (bahasaInput == "Indonesia" ? "Tren" : "Trend"), text_color = dimTrend, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, 4, trendDisplay + trendConf, text_color = f_colorScore(trendScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = trendDetail)
        if isDetailed
            table.cell(tblFull, 0, 5, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, 5, trendDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Momentum
        momDisplay = str.tostring(math.round(momentumScore))
        momArrow = not na(momentumScore) ? (momentumScore >= 70 ? "↑" : momentumScore >= 40 ? "→" : "↓") : "—"
        momConf = not na(momBull) ? " (" + f_confStr(momBull, momTotal) + ")" : ""
        momBase = 6
        if isDetailed
            momBase := 7
        table.cell(tblFull, 0, momBase, "  " + momArrow + " " + (bahasaInput == "Indonesia" ? "Momentum" : "Momentum"), text_color = dimMomentum, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, momBase, momDisplay + momConf, text_color = f_colorScore(momentumScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = momDetail)
        if isDetailed
            table.cell(tblFull, 0, momBase + 1, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, momBase + 1, momDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Volatility
        volDisplay = str.tostring(math.round(volatilityScore))
        volArrow = not na(volatilityScore) ? (volatilityScore >= 70 ? "≈" : volatilityScore >= 40 ? "→" : "⚡") : "—"
        volConf = not na(volBull) ? " (" + f_confStr(volBull, volTotal) + ")" : ""
        volBase = momBase + (isDetailed ? 2 : 1)
        table.cell(tblFull, 0, volBase, "  " + volArrow + " " + (bahasaInput == "Indonesia" ? "Volatilitas" : "Volatility"), text_color = dimVolatility, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, volBase, volDisplay + volConf, text_color = f_colorScore(volatilityScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = volDetail)
        if isDetailed
            table.cell(tblFull, 0, volBase + 1, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, volBase + 1, volDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Volume
        volmDisplay = str.tostring(math.round(volumeScore))
        volmArrow = not na(volumeScore) ? (volumeScore >= 70 ? "↑" : volumeScore >= 40 ? "→" : "↓") : "—"
        volmConf = not na(volmBull) ? " (" + f_confStr(volmBull, volmTotal) + ")" : ""
        volmBase = volBase + (isDetailed ? 2 : 1)
        table.cell(tblFull, 0, volmBase, "  " + volmArrow + " " + (bahasaInput == "Indonesia" ? "Volume" : "Volume"), text_color = dimVolume, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, volmBase, volmDisplay + volmConf, text_color = f_colorScore(volumeScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = volmDetail)
        if isDetailed
            table.cell(tblFull, 0, volmBase + 1, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, volmBase + 1, volmDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Smart Money (if enabled)
        if enableSmartMoney
            smBase = volmBase + (isDetailed ? 2 : 1)
            smDisplay = str.tostring(math.round(smartMoneyScore))
            smTooltip = not na(smartMoneyScore) ? (smDetected ? "SM flow: detected" : "SM flow: none") : ""
            table.cell(tblFull, 0, smBase, "  ◆ " + (bahasaInput == "Indonesia" ? "Smart Money" : "Smart Money"), text_color = color.rgb(255, 64, 129), text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, smBase, smDisplay, text_color = f_colorScore(smartMoneyScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = smTooltip)

        // Legend (last row)
        legendBase = volmBase + (isDetailed ? 2 : 1)
        if enableSmartMoney
            legendBase := legendBase + (isDetailed ? 1 : 1)
        legendText = bahasaInput == "Indonesia"
         ? "🔴 <40 Bearish | 🟡 40-70 Netral | 🟢 >70 Bullish"
         : "🔴 <40 Bearish | 🟡 40-70 Neutral | 🟢 >70 Bullish"
        table.cell(tblFull, 0, legendBase, legendText, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

// ==========================================================
// 3. ALERTS
// ==========================================================
// Alert: Signal Change
if ta.cross(overallScore, 70) or ta.cross(overallScore, 40)
    alert("PAPAN GERAK: Sinyal berubah menjadi " + signalText)

// Alert: Trend Extreme
if trendScore >= 80 or trendScore <= 20
    alert("PAPAN GERAK: Trend ekstrem (" + str.tostring(math.round(trendScore)) + ")")

// Alert: Momentum Oversold
if rsiOsHit
    alert("PAPAN GERAK: RSI oversold (" + str.tostring(math.round(rsiValue)) + ")")

// Alert: Momentum Overbought
if rsiObHit
    alert("PAPAN GERAK: RSI overbought (" + str.tostring(math.round(rsiValue)) + ")")

// Alert: Volume Spike
if volSpike
    alert("PAPAN GERAK: Volume spike (" + str.tostring(math.round(volRatio * 100)) + "% of MA)")

// Alert: Smart Money Detected
if smDetected
    alert("PAPAN GERAK: Institutional flow terdeteksi")

// Alert: Choppiness (ranging market)
if chopRanging
    alert("PAPAN GERAK: Pasar ranging (Choppiness: " + str.tostring(math.round(chopValue)) + ")")

