// @version=6
// 04-ui.pine — Papan Gerak: Table & Signal Rendering
// ==========================================================

// ==========================================================
// 1. SIGNAL LINE (Overall Score as Oscillator)
// ==========================================================
hline(70, "OB Line", color = color.rgb(239, 83, 80, 60), linestyle = hline.style_dashed)
hline(40, "OS Line", color = color.rgb(38, 166, 154, 60), linestyle = hline.style_dashed)
hline(50, "Midline", color = color.rgb(100, 100, 100, 40), linestyle = hline.style_dotted)

plot(overallScore, "Overall Score", signalColor, 2, plot.style_line)
fill(plot(70), plot(40), color = color.rgb(100, 100, 100, 10))

oscBg = na(overallScore) ? color.new(color.gray, 95) : overallScore >= 70 ? color.new(bullColor, 88) : overallScore >= 40 ? color.new(neutralColor, 88) : color.new(bearColor, 88)
bgcolor(oscBg, title = "Score Zone")

// ==========================================================
// 2. BUILD TABLE
// ==========================================================
f_getPosition() =>
    if tablePositionInput == "Top Left"
        position.top_left
    else
        if tablePositionInput == "Bottom Left"
            position.bottom_left
        else
            if tablePositionInput == "Bottom Right"
                position.bottom_right
            else
                position.top_right

f_getFontSize() =>
    if fontSizeInput == 1
        size.small
    else
        if fontSizeInput == 2
            size.normal
        else
            size.large

tablePos = f_getPosition()
fontSz = f_getFontSize()

// Render on last bar only
if barstate.islast
    // --- Compact Mode ---
    if modeInput == "Compact"
        tblCompact = table.new(tablePos, 2, 1, bgcolor = tableBgColor, border_width = 1, border_color = signalColor)
        overallDisplay = str.tostring(math.round(overallScore))
        table.cell(tblCompact, 0, 0, "PAPAN GERAK  " + signalText + "  " + overallDisplay,
         text_color = signalColor, text_size = fontSz, text_halign = text.align_center, width = 10)

    else
        // --- Standard & Detailed Mode ---
        isDetailed = modeInput == "Detailed"
        rowCount = 8
        if enableSmartMoney
            rowCount := 9
        if isDetailed
            rowCount := rowCount + 4  // +1 sub-row per dimensi
        tblFull = table.new(tablePos, 3, rowCount, bgcolor = tableBgColor, border_width = 1, border_color = signalColor,
         frame_color = signalColor, frame_width = 1)

        // Narrative row (full width)
        table.merge_cells(tblFull, 0, 0, 3, 1)
        table.cell(tblFull, 0, 0, narrative, text_color = headerColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Header
        table.cell(tblFull, 0, 1, "PAPAN GERAK", text_color = headerColor, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        overallDisplay = str.tostring(math.round(overallScore))
        overallTip = not na(overallScore) ? (overallScore >= 70 ? "Bullish: overall >70" : overallScore >= 40 ? "Neutral: 40-70" : "Bearish: <40") : ""
        table.cell(tblFull, 1, 1, overallDisplay, text_color = signalColor, text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = overallTip)

        // Signal
        table.cell(tblFull, 0, 2, bahasaInput == "Indonesia" ? "Sinyal" : "Signal", text_color = labelColor, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, 2, signalText, text_color = signalColor, text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor)

        // Confluence display helper
        f_confStr(n, total) =>
            str.tostring(n) + "/" + str.tostring(total)

        // Trend
        trendDisplay = str.tostring(math.round(trendScore))
        trendArrow = not na(trendScore) ? (trendScore >= 70 ? "↑" : trendScore >= 40 ? "→" : "↓") : "—"
        trendConf = not na(trendBull) ? " (" + f_confStr(trendBull, trendTotal) + ")" : ""
        table.cell(tblFull, 0, 3, "  " + trendArrow + " " + (bahasaInput == "Indonesia" ? "Tren" : "Trend"), text_color = dimTrend, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, 3, trendDisplay + trendConf, text_color = f_colorScore(trendScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = trendDetail)
        if isDetailed
            table.cell(tblFull, 0, 4, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, 4, trendDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Momentum
        momDisplay = str.tostring(math.round(momentumScore))
        momArrow = not na(momentumScore) ? (momentumScore >= 70 ? "↑" : momentumScore >= 40 ? "→" : "↓") : "—"
        momConf = not na(momBull) ? " (" + f_confStr(momBull, momTotal) + ")" : ""
        momBase = 5
        if isDetailed
            momBase := 6
        table.cell(tblFull, 0, momBase, "  " + momArrow + " " + (bahasaInput == "Indonesia" ? "Momentum" : "Momentum"), text_color = dimMomentum, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, momBase, momDisplay + momConf, text_color = f_colorScore(momentumScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = momDetail)
        if isDetailed
            table.cell(tblFull, 0, momBase + 1, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, momBase + 1, momDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Volatility
        volDisplay = str.tostring(math.round(volatilityScore))
        volArrow = not na(volatilityScore) ? (volatilityScore >= 70 ? "≈" : volatilityScore >= 40 ? "→" : "⚡") : "—"
        volConf = not na(volBull) ? " (" + f_confStr(volBull, volTotal) + ")" : ""
        volBase = momBase + (isDetailed ? 2 : 1)
        table.cell(tblFull, 0, volBase, "  " + volArrow + " " + (bahasaInput == "Indonesia" ? "Volatilitas" : "Volatility"), text_color = dimVolatility, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, volBase, volDisplay + volConf, text_color = f_colorScore(volatilityScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = volDetail)
        if isDetailed
            table.cell(tblFull, 0, volBase + 1, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, volBase + 1, volDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Volume
        volmDisplay = str.tostring(math.round(volumeScore))
        volmArrow = not na(volumeScore) ? (volumeScore >= 70 ? "↑" : volumeScore >= 40 ? "→" : "↓") : "—"
        volmConf = not na(volmBull) ? " (" + f_confStr(volmBull, volmTotal) + ")" : ""
        volmBase = volBase + (isDetailed ? 2 : 1)
        table.cell(tblFull, 0, volmBase, "  " + volmArrow + " " + (bahasaInput == "Indonesia" ? "Volume" : "Volume"), text_color = dimVolume, text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
        table.cell(tblFull, 1, volmBase, volmDisplay + volmConf, text_color = f_colorScore(volumeScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = volmDetail)
        if isDetailed
            table.cell(tblFull, 0, volmBase + 1, "", text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, volmBase + 1, volmDetail, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

        // Smart Money (if enabled)
        if enableSmartMoney
            smBase = volmBase + (isDetailed ? 2 : 1)
            smDisplay = str.tostring(math.round(smartMoneyScore))
            smTooltip = not na(smartMoneyScore) ? (smDetected ? "SM flow: detected" : "SM flow: none") : ""
            table.cell(tblFull, 0, smBase, "  ◆ " + (bahasaInput == "Indonesia" ? "Smart Money" : "Smart Money"), text_color = color.rgb(255, 64, 129), text_size = fontSz, text_halign = text.align_left, bgcolor = bgColor)
            table.cell(tblFull, 1, smBase, smDisplay, text_color = f_colorScore(smartMoneyScore), text_size = fontSz, text_halign = text.align_right, bgcolor = bgColor, tooltip = smTooltip)

        // Legend (last row)
        legendBase = volmBase + (isDetailed ? 2 : 1)
        if enableSmartMoney
            legendBase := legendBase + (isDetailed ? 1 : 1)
        legendText = bahasaInput == "Indonesia"
         ? "🔴 <40 Bearish | 🟡 40-70 Netral | 🟢 >70 Bullish"
         : "🔴 <40 Bearish | 🟡 40-70 Neutral | 🟢 >70 Bullish"
        table.cell(tblFull, 0, legendBase, legendText, text_color = labelColor, text_size = size.small, text_halign = text.align_left, bgcolor = bgColor)

// ==========================================================
// 3. ALERTS
// ==========================================================
// Alert: Signal Change
if ta.cross(overallScore, 70) or ta.cross(overallScore, 40)
    alert("PAPAN GERAK: Sinyal berubah menjadi " + signalText)

// Alert: Trend Extreme
if trendScore >= 80 or trendScore <= 20
    alert("PAPAN GERAK: Trend ekstrem (" + str.tostring(math.round(trendScore)) + ")")

// Alert: Momentum Oversold
if rsiOsHit
    alert("PAPAN GERAK: RSI oversold (" + str.tostring(math.round(rsiValue)) + ")")

// Alert: Momentum Overbought
if rsiObHit
    alert("PAPAN GERAK: RSI overbought (" + str.tostring(math.round(rsiValue)) + ")")

// Alert: Volume Spike
if volSpike
    alert("PAPAN GERAK: Volume spike (" + str.tostring(math.round(volRatio * 100)) + "% of MA)")

// Alert: Smart Money Detected
if smDetected
    alert("PAPAN GERAK: Institutional flow terdeteksi")

// Alert: Choppiness (ranging market)
if chopRanging
    alert("PAPAN GERAK: Pasar ranging (Choppiness: " + str.tostring(math.round(chopValue)) + ")")
