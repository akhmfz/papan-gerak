// @version=6
// 03-scoring.pine — Papan Gerak: Scoring Engine + Render
// ==========================================================

// ==========================================================
// 1. TREND SCORE (0-100)
// ==========================================================
f_trendScore() =>
    scoreSum = 0.0
    count = 0.0

    // EMA Position (weight: 3)
    pos = emaPosition
    if not na(pos)
        scoreSum += (pos + 1) / 3 * 100 * 3
        count += 3

    // SuperTrend Direction (weight: 2)
    if not na(superTrendDir)
        scoreSum += (superTrendDir == 1 ? 100 : 0) * 2
        count += 2

    // ADX Strength (weight: 2)
    if not na(adxValue)
        adxScore = adxStrong ? (adxTrend == 1 ? 80 : 20) : 50
        scoreSum += adxScore * 2
        count += 2

    // Trend Alignment (weight: 1 — sinyal echo, bukan indepen)
    if not na(adxValue)
        alignScore = trendAligned ? (adxTrend == 1 ? 100 : 0) : 50
        scoreSum += alignScore * 1
        count += 1

    // EMA Slope — rate of change (weight: 1)
    // [1] ratio dipilih alih-alih [5] offset agar konsisten di semua timeframe.
    // Pada monthly chart, [5] = 5 bulan (~150 hari) tidak relevan untuk slope jangka pendek.
    slopeFast = emaFast / emaFast[1] - 1
    if not na(slopeFast)
        slopeScore = f_scoreHigher(slopeFast, -0.02, 0.02)
        scoreSum += slopeScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 2. MOMENTUM SCORE (0-100)
// ==========================================================
f_momentumScore() =>
    scoreSum = 0.0
    count = 0.0

    // RSI (weight: 3)
    if not na(rsiValue)
        rsiScore = f_scoreHigher(rsiValue, 30, 70)
        scoreSum += rsiScore * 3
        count += 3

    // MACD (weight: 3)
    if not na(macdHist)
        macdScore = 50.0
        if macdBullish and macdHistRising
            macdScore := macdZero ? 90 : 70
        else
            if macdBullish
                macdScore := macdZero ? 70 : 55
            else
                if macdHistRising
                    macdScore := 45
                else
                    macdScore := macdZero ? 35 : 10
        scoreSum += macdScore * 3
        count += 3

    // Stochastic (weight: 2)
    if not na(stochKVal)
        stochScore = f_scoreHigher(stochKVal, 20, 80)
        scoreSum += stochScore * 2
        count += 2

    // RSI Direction (weight: 1)
    if not na(rsiDirection)
        dirScore = rsiDirection == 1 ? 70 : 30
        scoreSum += dirScore * 1
        count += 1

    // MACD Histogram Slope (weight: 1)
    if not na(macdHist) and not na(macdHist[2])
        slopeScore = macdHist > macdHist[2] ? 70 : 30
        scoreSum += slopeScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 3. VOLATILITY SCORE (0-100)
// ==========================================================
f_volatilityScore() =>
    scoreSum = 0.0
    count = 0.0

    // Bollinger Width vs Average (weight: 3)
    if not na(bbWidth) and not na(bbWidthAvg)
        // Squeeze = low volatility, Expansion = high volatility
        widthRatio = bbWidth / bbWidthAvg
        // Ideal: moderate volatility (0.8-1.2x average)
        volScore = f_scoreRange(widthRatio, 0.3, 3.0, 0.8, 1.2)
        scoreSum += volScore * 3
        count += 3

    // Choppiness Index (weight: 3)
    if not na(chopValue)
        // Low chop = trending (good), High chop = ranging (bad)
        chopScore = 100 - math.min(100, chopValue)
        scoreSum += chopScore * 3
        count += 3

    // ATR% (weight: 2)
    if not na(atrPercent)
        // Moderate ATR is ideal
        atrScore = f_scoreRange(atrPercent, 0.5, 10.0, 1.0, 3.0)
        scoreSum += atrScore * 2
        count += 2

    // Bollinger Position (weight: 1)
    if not na(bbPosition)
        // Price near middle = moderate, near bands = extreme
        posScore = 100 - math.abs(bbPosition - 50) * 2
        scoreSum += posScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 4. VOLUME SCORE (0-100)
// ==========================================================
f_volumeScore() =>
    scoreSum = 0.0
    count = 0.0

    // Volume vs MA (weight: 3)
    if not na(volRatio)
        volScore = f_scoreRange(volRatio, 0.2, 5.0, 0.8, 2.0)
        scoreSum += volScore * 3
        count += 3

    // OBV Agreement (weight: 3)
    if not na(obvValue)
        obvScore = obvAgree ? 80 : 30
        scoreSum += obvScore * 3
        count += 3

    // Net Volume Direction (weight: 2)
    if not na(netVolSmooth)
        netScore = netVolSmooth > 0 ? 70 : 30
        scoreSum += netScore * 2
        count += 2

    // Volume Spike Quality (weight: 1)
    if not na(volRatio)
        spikeScore = 50.0
        if volSpike
            closeInUpperHalf = close >= (high + low) / 2
            netPositive = not na(netVolSmooth) and netVolSmooth > 0
            spikeScore := closeInUpperHalf and netPositive ? 90 : closeInUpperHalf or netPositive ? 70 : 30
        scoreSum += spikeScore * 1
        count += 1

    count > 0 ? scoreSum / count : na

// ==========================================================
// 5. SMART MONEY SCORE (Optional, 0-100)
// ==========================================================
f_smartMoneyScore() =>
    if not enableSmartMoney
        na
    else
        scoreSum = 0.0
        count = 0.0

        // SM Detection (weight: 3)
        if not na(volume)
            scoreSum += (smDetected ? 90 : 50) * 3
            count += 3

        // Body Volume (weight: 2)
        if not na(volume)
            scoreSum += (smBodyVol ? 80 : 50) * 2
            count += 2

        // OBV Alignment (weight: 2)
        if not na(obvValue)
            scoreSum += (obvAgree ? 75 : 40) * 2
            count += 2

        // Net Volume (weight: 1)
        if not na(netVolSmooth)
            scoreSum += (netVolSmooth > 0 ? 70 : 40) * 1
            count += 1

        count > 0 ? scoreSum / count : na

// ==========================================================
// 6. MULTI-TIMEFRAME ALIGNMENT SCORE
// ==========================================================
f_mtfAlignmentScore() =>
    if not enableMTF
        [na, 0, "", na, na, na, na]

    tf1Dir = mtfTf1Trend * 0.55 + mtfTf1Mom * 0.45
    tf2Dir = mtfTf2Trend * 0.55 + mtfTf2Mom * 0.45
    tf3Dir = mtfTf3Trend * 0.55 + mtfTf3Mom * 0.45

    tf1Ctx = mtfTf1Vol * 0.55 + mtfTf1Volm * 0.45
    tf2Ctx = mtfTf2Vol * 0.55 + mtfTf2Volm * 0.45
    tf3Ctx = mtfTf3Vol * 0.55 + mtfTf3Volm * 0.45

    if na(tf1Dir) or na(tf2Dir)
        [na, 0, "", na, na, na, na]

    totalW = mtfPrimaryWeight + mtfSecondaryWeight + mtfTertiaryWeight
    normW1 = totalW > 0 ? mtfPrimaryWeight / totalW : 0.50
    normW2 = totalW > 0 ? mtfSecondaryWeight / totalW : 0.35
    normW3 = totalW > 0 ? mtfTertiaryWeight / totalW : 0.15

    mtfDirRaw = tf1Dir * normW1 + tf2Dir * normW2 + tf3Dir * normW3
    mtfCtxRaw = tf1Ctx * normW1 + tf2Ctx * normW2 + tf3Ctx * normW3

    f_bullConf(float score) => math.max(math.min((score - 50) / 20, 1), 0)
    f_bearConf(float score) => math.max(math.min((50 - score) / 20, 1), 0)

    tf1Bull = f_bullConf(tf1Dir)
    tf2Bull = f_bullConf(tf2Dir)
    tf3Bull = f_bullConf(tf3Dir)
    tf1Bear = f_bearConf(tf1Dir)
    tf2Bear = f_bearConf(tf2Dir)
    tf3Bear = f_bearConf(tf3Dir)

    weightedBull = tf1Bull * normW1 + tf2Bull * normW2 + tf3Bull * normW3
    weightedBear = tf1Bear * normW1 + tf2Bear * normW2 + tf3Bear * normW3

    hysteresis = mtfDirectionHysteresis / 100
    direction = if weightedBull > weightedBear + hysteresis
        1
    else if weightedBear > weightedBull + hysteresis
        -1
    else
        0

    maxDiv = math.max(math.abs(tf1Dir - tf2Dir), math.abs(tf1Dir - tf3Dir), math.abs(tf2Dir - tf3Dir))
    penalty = (maxDiv / 100) * mtfMaxPenalty

    conflictScore = mtfDirRaw * (1 - penalty)
    finalScore = conflictScore * mtfAlpha + mtfCtxRaw * (1 - mtfAlpha)

    debugStr = if mtfDebug
        "MTF DEBUG\n" +
        "  Primary (" + mtfPrimaryTF + "): T" + str.tostring(math.round(mtfTf1Trend)) +
        " M" + str.tostring(math.round(mtfTf1Mom)) +
        " V" + str.tostring(math.round(mtfTf1Vol)) +
        " Vo" + str.tostring(math.round(mtfTf1Volm)) + "\n" +
        "  Secondary (" + mtfSecondaryTF + "): T" + str.tostring(math.round(mtfTf2Trend)) +
        " M" + str.tostring(math.round(mtfTf2Mom)) +
        " V" + str.tostring(math.round(mtfTf2Vol)) +
        " Vo" + str.tostring(math.round(mtfTf2Volm)) + "\n" +
        "  Tertiary (" + mtfTertiaryTF + "): T" + str.tostring(math.round(mtfTf3Trend)) +
        " M" + str.tostring(math.round(mtfTf3Mom)) +
        " V" + str.tostring(math.round(mtfTf3Vol)) +
        " Vo" + str.tostring(math.round(mtfTf3Volm)) + "\n" +
        "  Dir: " + (direction == 1 ? "Bullish" : direction == -1 ? "Bearish" : "Mixed") +
        " | Pen: " + str.tostring(math.round(penalty * 100)) + "%" +
        " | DirRaw: " + str.tostring(math.round(mtfDirRaw)) +
        " | CtxRaw: " + str.tostring(math.round(mtfCtxRaw)) +
        " | Final: " + str.tostring(math.round(finalScore))
    else
        ""

    [finalScore, direction, debugStr, tf1Dir, tf2Dir, tf3Dir, penalty]

[mtfScore, mtfDirection, mtfDebugStr, mtfTf1Dir, mtfTf2Dir, mtfTf3Dir, mtfPenalty] = f_mtfAlignmentScore()

// ==========================================================
// 7. CALCULATE ALL SCORES
// ==========================================================
trendScore = f_trendScore()
momentumScore = f_momentumScore()
volatilityScore = f_volatilityScore()
volumeScore = f_volumeScore()
smartMoneyScore = f_smartMoneyScore()

// Normalize weights
totalWeight = weightTrend + weightMomentum + weightVolatility + weightVolume
normTrend = totalWeight > 0 ? weightTrend / totalWeight * 100 : 25
normMomentum = totalWeight > 0 ? weightMomentum / totalWeight * 100 : 25
normVolatility = totalWeight > 0 ? weightVolatility / totalWeight * 100 : 25
normVolume = totalWeight > 0 ? weightVolume / totalWeight * 100 : 25

float overallScore = na
if not na(trendScore) or not na(momentumScore) or not na(volatilityScore) or not na(volumeScore)
    sum = 0.0
    wSum = 0.0
    if not na(trendScore)
        sum += trendScore * normTrend
        wSum += normTrend
    if not na(momentumScore)
        sum += momentumScore * normMomentum
        wSum += normMomentum
    if not na(volatilityScore)
        sum += volatilityScore * normVolatility
        wSum += normVolatility
    if not na(volumeScore)
        sum += volumeScore * normVolume
        wSum += normVolume
    if not na(smartMoneyScore) and enableSmartMoney
        sum += smartMoneyScore * weightSmartMoney
        wSum += weightSmartMoney
    overallScore := wSum > 0 ? sum / wSum : na

// ==========================================================
// 7. SIGNAL GENERATION
// ==========================================================
signalText = f_signalText(overallScore, bahasaInput)
signalColor = f_colorScore(overallScore)

// ==========================================================
// 8. CONFLUENCE COUNTERS (berapa sub-indikator setuju per dimensi)
// ==========================================================
// Trend
trendBull = 0
trendTotal = 0
if not na(emaPosition)
    trendBull += emaPosition >= 1 ? 1 : 0
    trendTotal += 1
if not na(superTrendDir)
    trendBull += superTrendDir == 1 ? 1 : 0
    trendTotal += 1
if not na(adxValue)
    trendBull += (adxStrong and adxTrend == 1) ? 1 : 0
    trendTotal += 1
if not na(adxValue)
    trendBull += trendAligned ? 1 : 0
    trendTotal += 1

// Momentum
momBull = 0
momTotal = 0
if not na(rsiValue)
    momBull += rsiValue > 50 ? 1 : 0
    momTotal += 1
if not na(macdLine)
    momBull += macdBullish ? 1 : 0
    momTotal += 1
if not na(stochKVal)
    momBull += stochBullish ? 1 : 0
    momTotal += 1
if not na(rsiDirection)
    momBull += rsiDirection == 1 ? 1 : 0
    momTotal += 1
if not na(macdHist)
    momBull += macdHistRising ? 1 : 0
    momTotal += 1

// Volatility ("ideal" = trending/tenang, bukan ranging/liar)
volBull = 0
volTotal = 0
if not na(bbWidth) and not na(bbWidthAvg)
    volBull += (bbWidth / bbWidthAvg >= 0.8 and bbWidth / bbWidthAvg <= 1.2) ? 1 : 0
    volTotal += 1
if not na(chopValue)
    volBull += chopValue <= 38 ? 1 : 0
    volTotal += 1
if not na(atrPercent)
    volBull += (atrPercent >= 1.0 and atrPercent <= 3.0) ? 1 : 0
    volTotal += 1
if not na(bbPosition)
    volBull += (bbPosition >= 30 and bbPosition <= 70) ? 1 : 0
    volTotal += 1

// Volume
volmBull = 0
volmTotal = 0
if not na(volRatio)
    volmBull += volRatio >= 0.8 ? 1 : 0
    volmTotal += 1
if not na(obvValue)
    volmBull += obvAgree ? 1 : 0
    volmTotal += 1
if not na(netVolSmooth)
    volmBull += netVolSmooth > 0 ? 1 : 0
    volmTotal += 1
if not na(volRatio)
    volmBull += volSpike ? 1 : 0
    volmTotal += 1

// ==========================================================
// 9. TOOLTIP STRINGS (detail per dimensi untuk hover)
// ==========================================================
// Trend tooltip
trendDetail = "—"
if not na(emaPosition) and not na(trendScore)
    emaLabel = emaPosition >= 1 ? "Price > EMA50 ✓" : emaPosition >= 0 ? "Price > EMA20" : "Price < EMAs ✗"
    stLabel = not na(superTrendDir) ? (superTrendDir == 1 ? "SuperTrend Up ✓" : "SuperTrend Down ✗") : ""
    adxLabel = not na(adxValue) ? (adxStrong ? (adxTrend == 1 ? "ADX " + str.tostring(math.round(adxValue)) + " (strong) ✓" : "ADX " + str.tostring(math.round(adxValue)) + " (strong, down)") : "ADX " + str.tostring(math.round(adxValue)) + " (weak)") : ""
    alignLabel = not na(adxValue) ? (trendAligned ? "Aligned ✓" : "Mixed") : ""
    trendDetail := emaLabel + " | " + stLabel + " | " + adxLabel + " | " + alignLabel

// Momentum tooltip
momDetail = "—"
if not na(rsiValue) and not na(momentumScore)
    rsiLbl = rsiValue >= rsiOb ? "RSI " + str.tostring(math.round(rsiValue)) + " Overbought" : rsiValue <= rsiOs ? "RSI " + str.tostring(math.round(rsiValue)) + " Oversold" : "RSI " + str.tostring(math.round(rsiValue)) + " Netral"
    macdLbl = macdBullish ? (macdHistRising ? "MACD Bullish + hist ↑" : "MACD Bullish + hist ↓") : (macdHistRising ? "MACD Bearish + hist ↑" : "MACD Bearish + hist ↓")
    stochLbl = not na(stochKVal) ? (stochKVal >= stochOb ? "Stoch Overbought" : stochKVal <= stochOs ? "Stoch Oversold" : "Stoch " + str.tostring(math.round(stochKVal)) + " Netral") : ""
    momDetail := rsiLbl + " | " + macdLbl + " | " + stochLbl

// Volatility tooltip
volDetail = "—"
if not na(bbWidth) and not na(atrPercent) and not na(volatilityScore)
    bbRatio = bbWidth / bbWidthAvg
    bbLbl = bbRatio >= 0.8 and bbRatio <= 1.2 ? "BB Moderate ✓" : bbRatio < 0.8 ? "BB Squeeze" : "BB Expand"
    chopLbl = not na(chopValue) ? (chopValue <= 38 ? "Chop " + str.tostring(math.round(chopValue)) + " Trending ✓" : chopValue >= 62 ? "Chop " + str.tostring(math.round(chopValue)) + " Ranging" : "Chop " + str.tostring(math.round(chopValue)) + " Netral") : ""
    atrLbl = "ATR " + str.tostring(math.round(atrPercent * 10) / 10) + "%"
    bbPosLbl = not na(bbPosition) ? (bbPosition >= 30 and bbPosition <= 70 ? "BB Pos " + str.tostring(math.round(bbPosition)) + " Mid ✓" : "BB Pos " + str.tostring(math.round(bbPosition)) + " Edge") : ""
    volDetail := bbLbl + " | " + chopLbl + " | " + atrLbl + " | " + bbPosLbl

// Volume tooltip
volmDetail = "—"
if not na(volRatio) and not na(volumeScore)
    vrLbl = volRatio >= volSpikeMult ? "Vol " + str.tostring(math.round(volRatio * 10) / 10) + "x (spike!)" : volRatio >= 0.8 ? "Vol " + str.tostring(math.round(volRatio * 10) / 10) + "x (healthy) ✓" : "Vol " + str.tostring(math.round(volRatio * 10) / 10) + "x (low)"
    obvLbl = not na(obvValue) ? (obvAgree ? "OBV Agree ✓" : "OBV Diverge ✗") : ""
    netLbl = not na(netVolSmooth) ? (netVolSmooth > 0 ? "Net Vol + Bullish" : "Net Vol - Bearish") : ""
    spikeLbl = volSpike ? "Spike ✓" : "Spike ✗"
    volmDetail := vrLbl + " | " + obvLbl + " | " + netLbl + " | " + spikeLbl

// ==========================================================
// 10. MULTI-TIMEFRAME CONFLICT DETECTION
// ==========================================================
// Legacy conflict (simple binary, for backward compat)
mtfConflict = enableMtfFilter and not na(mtfTrendScore) and not na(overallScore) and (
    (mtfTrendScore >= 50 and overallScore < 40) or
    (mtfTrendScore < 50 and overallScore >= 70)
)

mtfWarning = if enableMtfFilter and not na(mtfTrendScore)
    if mtfTrendScore >= 50
        (bahasaInput == "Indonesia" ? "MTF ▲ " + str.tostring(math.round(mtfTrendScore)) : "MTF ▲ " + str.tostring(math.round(mtfTrendScore)))
    else
        (bahasaInput == "Indonesia" ? "MTF ▼ " + str.tostring(math.round(mtfTrendScore)) : "MTF ▼ " + str.tostring(math.round(mtfTrendScore)))
else
    ""

// New MTF alignment summary (for UI — Sprint C)
mtfAlignmentDirection = if not na(mtfScore)
    if mtfDirection == 1
        "Bullish"
    else if mtfDirection == -1
        "Bearish"
    else
        "Mixed"
else
    ""

// ==========================================================
// 11. NARRATIVE (1 baris insight untuk trader)
// ==========================================================
f_narrative() =>
    lang = bahasaInput

    if not na(momentumScore) and not na(rsiValue) and not na(trendScore) and not na(overallScore)
        // 1. Momentum kuat tapi RSI overbought — prioritas tertinggi (konflik)
        if momentumScore >= 65 and rsiValue >= rsiOb
            lang == "Indonesia" ? "⚠️  Momentum kuat tapi RSI overbought — waspada koreksi" : "⚠️  Strong momentum but RSI overbought — watch for pullback"

        // 2. RSI oversold + volume spike = potensi bounce
        else if rsiValue <= rsiOs and not na(volRatio) and volSpike
            lang == "Indonesia" ? "📈 RSI oversold + volume spike — potensi bounce" : "📈 RSI oversold + volume spike — potential bounce"

        // 3. Tren lemah & volatil
        else if not na(volatilityScore) and trendScore < 40 and volatilityScore < 40
            lang == "Indonesia" ? "⚠️  Tren lemah & volatil — hindari entry baru" : "⚠️  Weak trend & volatile — avoid new entries"

        // 4. Volume konfirmasi tren
        else if trendScore >= 65 and not na(volmBull) and not na(volmTotal) and volmBull >= 3 and volmTotal >= 3
            lang == "Indonesia" ? "✅ Volume konfirmasi tren — bias searah" : "✅ Volume confirms trend — trade with trend"

        // 5. Semua align bullish
        else if overallScore >= 70 and trendScore >= 65 and not na(volmBull) and volmBull >= 3
            lang == "Indonesia" ? "✅ Semua dimensi align — bias bullish" : "✅ All dimensions aligned — bullish bias"

        // 6. Semua align bearish
        else if overallScore <= 30 and not na(trendScore) and trendScore <= 35 and not na(volmBull) and volmBull <= 1
            lang == "Indonesia" ? "✅ Semua dimensi align — bias bearish" : "✅ All dimensions aligned — bearish bias"

        // 7. OBV divergen
        else if not na(obvValue) and close > close[10] and not obvAgree
            lang == "Indonesia" ? "⚠️  Harga naik tapi OBV divergen — konfirmasi dulu" : "⚠️  Price up but OBV diverging — confirm first"

        // 8. MTF conflict
        else if enableMtfFilter and not na(mtfTrendScore) and mtfConflict and not na(overallScore)
            isBullishDaily = overallScore >= 70
            if lang == "Indonesia"
                if isBullishDaily
                    "⚠️  Tren " + mtfTimeframe + " bearish — sinyal harian perlu konfirmasi"
                else
                    "⚠️  Tren " + mtfTimeframe + " bullish — jangan short saat tren besar naik"
            else
                if isBullishDaily
                    "⚠️  " + mtfTimeframe + " trend bearish — confirm daily signal"
                else
                    "⚠️  " + mtfTimeframe + " trend bullish — don't short against higher TF"

        // 9. Ranging market
        else if not na(chopValue) and chopRanging
            lang == "Indonesia" ? "⏳ Pasar ranging — tunggu breakout" : "⏳ Ranging market — wait for breakout"

        // 10. Fallback: mixed
        else
            lang == "Indonesia" ? "💡 Kondisi campuran — cek detail per dimensi" : "💡 Mixed conditions — check per-dimension details"
    else
        lang == "Indonesia" ? "⏳ Menunggu data..." : "⏳ Waiting for data..."

narrative = f_narrative()

// ==========================================================
// 12. ENTRY TRIGGER ENGINE (3 modes)
// ==========================================================
// Zone tracking (untuk Composite Score mode)
currentZone = na(overallScore) ? -1 : (overallScore >= 70 ? 2 : overallScore >= 40 ? 1 : 0)
var int prevZone = -1
if prevZone < 0 and currentZone >= 0
    prevZone := currentZone
var int lastSignalBar = -1
var float signalEntryPrice = na
var int signalEntryBar = na
var int signalDirection = 0  // 1 = long, -1 = short
var string signalLabel = ""

zoneChanged = prevZone >= 0 and currentZone >= 0 and currentZone != prevZone
minBarsOk = lastSignalBar < 0 or bar_index - lastSignalBar >= minSignalBars
chopFilterOk = signalFilterMode == "Disabled" or (not na(chopValue) and (
    signalFilterMode == "Only Trending (Chop<38)" ? chopValue < 38 :
    signalFilterMode == "Only Ranging (Chop>62)" ? chopValue >= 62 : true
))

// Mode A: Composite Score (zone-based)
signalTriggered = zoneChanged and minBarsOk and chopFilterOk

// Mode B: Pullback (trend pullback ke EMA20 + RSI rebound)
pullbackTrigger = entryTriggerMode == "Pullback" and not na(trendScore) and trendScore >= 65 and not na(emaFast) and not na(atrValue) and math.abs(close - emaFast) <= atrValue * 1.5 and not na(rsiValue) and rsiValue <= 50 and rsiDirection == 1 and minBarsOk and chopFilterOk

// Mode C: Breakout (price break recent high/low + volume confirmation)
recentHigh = ta.highest(high, 20)
recentLow = ta.lowest(low, 20)
breakoutTrigger = entryTriggerMode == "Breakout" and not na(volumeScore) and volumeScore >= 60 and (close >= recentHigh or close <= recentLow) and minBarsOk and chopFilterOk

// Unified entry trigger
entryTriggered = if entryTriggerMode == "Composite Score"
    signalTriggered
else if entryTriggerMode == "Pullback"
    pullbackTrigger
else
    breakoutTrigger

// Signal direction & label
if entryTriggered
    signalDir = if entryTriggerMode == "Composite Score"
        (currentZone > prevZone ? 1 : -1)
    else if entryTriggerMode == "Pullback"
        1
    else
        (close >= recentHigh ? 1 : -1)

    signalLbl = if entryTriggerMode == "Composite Score"
        if signalDir > 0
            if prevZone == 0
                (bahasaInput == "Indonesia" ? "Bearish→Netral (Bullish)" : "Bearish→Neutral (Bullish)")
            else
                (bahasaInput == "Indonesia" ? "Netral→Bullish" : "Neutral→Bullish")
        else
            if prevZone == 2
                (bahasaInput == "Indonesia" ? "Bullish→Netral (Bearish)" : "Bullish→Neutral (Bearish)")
            else
                (bahasaInput == "Indonesia" ? "Netral→Bearish" : "Neutral→Bearish")
    else if entryTriggerMode == "Pullback"
        (bahasaInput == "Indonesia" ? "Pullback Entry" : "Pullback Entry")
    else
        if signalDir > 0
            (bahasaInput == "Indonesia" ? "Breakout Long" : "Breakout Long")
        else
            (bahasaInput == "Indonesia" ? "Breakout Short" : "Breakout Short")

    signalEntryPrice := close
    signalEntryBar := bar_index
    signalDirection := signalDir
    signalLabel := signalLbl
    lastSignalBar := bar_index

if zoneChanged
    prevZone := currentZone

// Forward return
fwdReturn = na(signalEntryPrice) or signalEntryPrice == 0 ? na : (close / signalEntryPrice - 1) * signalDirection * 100

signalStatus = na(fwdReturn) ? "" : fwdReturn >= 5 ? "✅ +" + str.tostring(math.round(fwdReturn)) + "%" : fwdReturn >= 0 ? "➖ +" + str.tostring(math.round(fwdReturn)) + "%" : fwdReturn >= -5 ? "➖ " + str.tostring(math.round(fwdReturn)) + "%" : "❌ " + str.tostring(math.round(fwdReturn)) + "%"

fwdBars = na(signalEntryBar) ? na : bar_index - signalEntryBar

// ==========================================================
// 13. HISTORI SINYAL (circular buffer, evaluasi setiap 10 bar)
// ==========================================================
LOOKBACK_BARS = 10
BT_SIZE = 20

var int[] btEntryBars = array.new_int(BT_SIZE, -1)
var float[] btEntryPrices = array.new_float(BT_SIZE, na)
var int[] btDirs = array.new_int(BT_SIZE, 0)
var int btHead = 0
var int btTotalEval = 0
var int btWins = 0
var float btTotalReturn = 0.0

// Record new signal
if entryTriggered
    array.set(btEntryBars, btHead, bar_index)
    array.set(btEntryPrices, btHead, close)
    array.set(btDirs, btHead, signalDirection)
    btHead := (btHead + 1) % BT_SIZE

// Evaluate resolved signals
btNewWins = 0
btNewLosses = 0
for i = 0 to BT_SIZE - 1
    eb = array.get(btEntryBars, i)
    if eb >= 0 and bar_index - eb >= LOOKBACK_BARS
        ep = array.get(btEntryPrices, i)
        ed = array.get(btDirs, i)
        ret = (close / ep - 1) * ed * 100
        btTotalReturn += ret
        if ret > 0
            btNewWins += 1
        else
            btNewLosses += 1
        array.set(btEntryBars, i, -1)

btTotalEval += btNewWins + btNewLosses
btWins += btNewWins

btWinRate = btTotalEval > 0 ? btWins / btTotalEval * 100 : na

// ==========================================================
// 14. LEVEL REFERENSI RISIKO (SL & Target)
// ==========================================================
var float riskEntryPrice = na
var float riskAtrCapture = na
var float riskSwingLow = na
var float riskSwingHigh = na
var int riskDirection = 0

// ta.lowest/ta.highest must be called unconditionally on every bar (Pine v6 requirement)
riskSwingLowUncond = ta.lowest(low, slSwingPeriod)
riskSwingHighUncond = ta.highest(high, slSwingPeriod)

if entryTriggered
    riskEntryPrice := signalEntryPrice
    riskAtrCapture := atrValue
    riskSwingLow := riskSwingLowUncond
    riskSwingHigh := riskSwingHighUncond
    riskDirection := signalDirection

hasRisk = riskDirection != 0 and not na(riskEntryPrice)

// ATR-based SL
atrSl = hasRisk ? riskEntryPrice - riskAtrCapture * slAtrMult * riskDirection : na

// Swing-based SL
swingSl = hasRisk ? (riskDirection == 1 ? riskSwingLow : riskSwingHigh) : na

// Final SL price
float slPrice = na
if hasRisk
    if slTypeInput == "ATR"
        slPrice := atrSl
    else if slTypeInput == "Swing Low/High"
        slPrice := swingSl
    else
        slPrice := riskDirection == 1 ? math.min(atrSl, swingSl) : math.max(atrSl, swingSl)

// Target (R-multiple: entry + Risk * targetR)
riskAmount = hasRisk ? math.abs(riskEntryPrice - slPrice) : na
targetPrice = hasRisk ? riskEntryPrice + riskAmount * targetR * riskDirection : na

// Format for display
slPct = hasRisk and riskEntryPrice != 0 ? riskAmount / riskEntryPrice * 100 : na
targetPct = hasRisk and riskEntryPrice != 0 ? math.abs(targetPrice - riskEntryPrice) / riskEntryPrice * 100 : na

riskBaseLabel = if hasRisk
    "SL: " + str.tostring(math.round(slPrice)) + " (" + (riskDirection == 1 ? "-" : "+") + str.tostring(math.round(slPct)) + "%)  |  Tgt: " + str.tostring(math.round(targetPrice)) + " (" + (riskDirection == 1 ? "+" : "-") + str.tostring(math.round(targetPct)) + "%)  [" + str.tostring(targetR) + "R]"
else
    "—"

// ==========================================================
// 15. POSITION SIZING
// ==========================================================
riskRp = showPositionSizing ? accountBalanceInput * riskPctInput / 100 : na
suggestedLots = showPositionSizing and not na(riskAmount) and riskAmount > 0 ? math.floor((riskRp / riskAmount) / 100) : na
riskRpK = not na(riskRp) and not na(suggestedLots) ? math.round(riskRp / 1000) : na
riskRpDisplay = not na(riskRpK) ? (riskRpK >= 1000 ? "Rp" + str.tostring(math.round(riskRpK / 1000)) + "jt" : "Rp" + str.tostring(riskRpK) + "rb") : ""
lotLabel = bahasaInput == "Indonesia" ? "Lot" : "Lots"

suggestedLotStr = if hasRisk and showPositionSizing and not na(suggestedLots)
    "  |  " + lotLabel + ": " + str.tostring(math.max(1, suggestedLots)) + (suggestedLots < 1 ? " (min. 1 lot)" : "") + "  |  " + riskRpDisplay + " (" + str.tostring(riskPctInput) + "%)"
else
    ""

riskLevelLabel = riskBaseLabel + suggestedLotStr
